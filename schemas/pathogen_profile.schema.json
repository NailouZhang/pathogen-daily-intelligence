{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PathogenProfile",
  "type": "object",
  "required": [
    "schema_version",
    "profile_id",
    "profile_version",
    "display_names",
    "search_policy"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "profile_id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "profile_version": {
      "type": "string"
    },
    "display_names": {
      "type": "object",
      "required": [
        "zh",
        "en"
      ]
    },
    "search_policy": {
      "type": "object",
      "required": [
        "window_days",
        "timezone"
      ]
    },
    "taxonomy": {
      "type": "object"
    },
    "provenance": {
      "type": "array"
    }
  },
  "additionalProperties": true
}