{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScholarlyWork",
  "type": "object",
  "required": [
    "schema_version",
    "work_id",
    "identifiers",
    "title",
    "source_records",
    "first_seen_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string"
    },
    "identifiers": {
      "type": "object"
    },
    "title": {
      "type": "object",
      "required": [
        "original"
      ],
      "properties": {
        "original": {
          "type": "string"
        },
        "translated_zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "source_records": {
      "type": "array"
    },
    "first_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "abstract": {
      "type": "object",
      "properties": {
        "original": {
          "type": [
            "string",
            "null"
          ]
        },
        "translated_zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "sentences": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "display_summary": {
      "type": "object",
      "properties": {
        "zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "translation_audit": {
      "type": [
        "object",
        "null"
      ]
    },
    "full_text": {
      "type": [
        "object",
        "null"
      ],
      "properties": {
        "available": {
          "type": "boolean"
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "url": {
          "type": [
            "string",
            "null"
          ]
        },
        "sections": {
          "type": "array"
        },
        "retrieved_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_level": {
          "type": [
            "string",
            "null"
          ]
        },
        "content_version": {
          "type": [
            "string",
            "null"
          ]
        },
        "license": {
          "type": [
            "string",
            "null"
          ]
        },
        "sha256": {
          "type": [
            "string",
            "null"
          ]
        },
        "extraction_method": {
          "type": [
            "string",
            "null"
          ]
        },
        "temporary_file_persisted": {
          "type": "boolean"
        },
        "availability_status": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "ai_analysis": {
      "type": [
        "object",
        "null"
      ]
    },
    "processing_audit": {
      "type": "object"
    },
    "evidence_acquisition": {
      "type": "object",
      "properties": {
        "status": {
          "type": [
            "string",
            "null"
          ]
        },
        "evidence_level": {
          "type": [
            "string",
            "null"
          ],
          "enum": [
            "E0",
            "E1",
            "E2",
            "E3",
            "E4",
            null
          ]
        },
        "analysis_eligible": {
          "type": "boolean"
        },
        "attempt_count": {
          "type": "integer",
          "minimum": 0
        },
        "last_attempt_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "retry_recommended": {
          "type": "boolean"
        },
        "reason_codes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "failed_stages": {
          "type": "array",
          "items": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "attempts": {
          "type": "array"
        },
        "copyright_policy": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
