{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ScholarlyWork",
  "type": "object",
  "required": [
    "schema_version",
    "work_id",
    "identifiers",
    "title",
    "source_records",
    "first_seen_at"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "work_id": {
      "type": "string"
    },
    "identifiers": {
      "type": "object"
    },
    "title": {
      "type": "object",
      "required": [
        "original"
      ],
      "properties": {
        "original": {
          "type": "string"
        },
        "translated_zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "source_records": {
      "type": "array"
    },
    "first_seen_at": {
      "type": [
        "string",
        "null"
      ]
    },
    "abstract": {
      "type": "object",
      "properties": {
        "original": {
          "type": [
            "string",
            "null"
          ]
        },
        "translated_zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "source": {
          "type": [
            "string",
            "null"
          ]
        },
        "sentences": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "display_summary": {
      "type": "object",
      "properties": {
        "zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "translation_audit": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
