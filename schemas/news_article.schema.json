{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "NewsArticle",
  "type": "object",
  "required": [
    "schema_version",
    "article_id",
    "canonical_url",
    "source",
    "title"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "article_id": {
      "type": "string"
    },
    "canonical_url": {
      "type": "string"
    },
    "source": {
      "type": "object"
    },
    "title": {
      "type": "object",
      "required": [
        "original"
      ],
      "properties": {
        "original": {
          "type": "string"
        },
        "translated_zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "language": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "content": {
      "type": "object",
      "properties": {
        "excerpt": {
          "type": [
            "string",
            "null"
          ]
        },
        "translated_excerpt_zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "sentences": {
          "type": "array"
        }
      },
      "additionalProperties": true
    },
    "display_summary": {
      "type": "object",
      "properties": {
        "zh": {
          "type": [
            "string",
            "null"
          ]
        },
        "en": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": false
    },
    "translation_audit": {
      "type": [
        "object",
        "null"
      ]
    }
  },
  "additionalProperties": true
}
